# Serveur API
API_PORT=8080
API_HOST=0.0.0.0

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=mailhive
DB_PASSWORD=mailhive_secret
DB_NAME=mailhive
DB_SSL_MODE=disable
# DB_MAX_CONNS doit être ≥ WORKER_CONCURRENCY (voir plus bas) pour éviter
# la contention des connexions sur les phases DB du worker.
DB_MAX_CONNS=50

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=changez-moi-en-production-avec-une-cle-de-64-chars-minimum
JWT_EXPIRATION=24h

# Admin
ADMIN_API_KEY=admin-key-a-changer-en-production

# Chiffrement SMTP
ENCRYPTION_KEY=32-bytes-hex-key-a-changer-00000

# Worker
WORKER_CONCURRENCY=50
WORKER_QUEUE_CRITICAL=6
WORKER_QUEUE_DEFAULT=3
WORKER_QUEUE_LOW=1

# Rate limiting par défaut
DEFAULT_RATE_LIMIT=100
DEFAULT_RATE_BURST=200

# Logging (slog) : LOG_LEVEL=debug|info|warn|error, LOG_FORMAT=text|json
LOG_LEVEL=info
LOG_FORMAT=text

# Mode SMTP : "real" (envoi réel) ou "simulation" (log uniquement)
SMTP_MODE=simulation

# Stockage des pièces jointes (dédupliquées par contenu, scope tenant)
# BLOB_BACKEND=postgres : contenu dans la table attachment_blobs (défaut, aucune infra externe)
# BLOB_BACKEND=s3       : object store compatible S3 (SeaweedFS, MinIO, S3, R2)
BLOB_BACKEND=postgres
BLOB_S3_ENDPOINT=
BLOB_S3_BUCKET=mailhive-attachments
BLOB_S3_ACCESS_KEY=
BLOB_S3_SECRET_KEY=
BLOB_S3_REGION=us-east-1
BLOB_S3_USE_SSL=false
